# Gateway (models.rapidmvp.io)
GATEWAY_BASE_URL=https://models.rapidmvp.io
GATEWAY_API_KEY=your-internal-api-key

# OpenRouter model for chat (e.g. openai/gpt-5-pro)
CHAT_MODEL=openai/gpt-5-pro
# Optional comma-separated allowlist for URL-provided ?model= overrides on /chatbot routes
# CHAT_MODEL_ALLOWLIST=openai/gpt-5-pro,openai/gpt-4o-mini

# Timeout for gateway request in ms (default 120000 = 2 min; increase if you see 504)
# GATEWAY_TIMEOUT_MS=120000

# Optional gateway timeout in ms
# GATEWAY_TIMEOUT_MS=120000

# Comma-separated browser origins allowed for CORS on /api/*
# Example:
# CHATBOT_CORS_ALLOWED_ORIGINS=https://rapidmvp.io,https://www.rapidmvp.io,https://taxflow.uk

# Comma-separated allowlist for iframe parents (used in CSP frame-ancestors on /chatbot routes)
# Example:
# CHATBOT_FRAME_ANCESTORS='self',https://rapidmvp.io,https://www.rapidmvp.io,https://*.sharepoint.com

